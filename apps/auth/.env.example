# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Database (Postgres) — users + sessions + OIDC state
# Used by both docker-compose (for container init) and the app (for connection)
POSTGRES_USER=auth
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=auth
DATABASE_URL=postgres://auth:replace-me@localhost:5433/auth

# CORS — Next.js (auth-web) and any client apps
# 쉼표로 여러 origin 구분 가능
CORS_ORIGIN=http://localhost:3000,http://localhost:3030

# better-auth
# Public URL this auth server is reachable at (used for issuer + redirects)
BETTER_AUTH_URL=http://localhost:3001
# Long random string used to sign cookies/tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# UI URL — login/consent screens hosted by apps/auth/web
WEB_URL=http://localhost:3000

# Seed 어드민 계정 비밀번호 (숫자+특수문자 포함 8자 이상 필수)
SEED_ADMIN_PASSWORD=replace-me-with-secure-password
